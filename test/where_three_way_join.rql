SOURCE "xyzzy"
SOURCE "plugh"

OUTPUT {
  ?x <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> ?z .
}

WHERE {
  GRAPH "xyzzy" { ?x <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> ?y . }
  AND
  GRAPH "plugh" { ?y <http://www.w3.org/2000/01/rdf-schema#subClassOf> ?z . }
  AND
  GRAPH "xyzzy" { ?x <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> ?again . }
}
