SOURCE "foo"

OUTPUT {
    ?s ?p ?o .
}

WHERE FILTER (
    ?s == <http://example.org/jane> && ?p != <http://ont.example.org/hasName> && !(?o == "Fred" || ?o == "Sally") 
    ||
    ?s != <http://example.org/jane> && ?p == <http://ont.example.org/hasName> && !(?o == "Fred" || ?o == "Sally") 
    ||
    ?s != <http://example.org/jane> && ?p != <http://ont.example.org/hasName> && (?o == "Fred" || ?o == "Sally") 
){
    ?s ?p ?o.
}