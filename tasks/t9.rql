SOURCE "foo"

OUTPUT {
    ?x <http://www.w3.org/2002/07/owl#sameAs> ?z .
}

WHERE {
    ?x <http://www.w3.org/2002/07/owl#sameAs> ?y .
    AND
    ?y <http://www.w3.org/2002/07/owl#sameAs> ?z .
    OR
    ?x <http://www.w3.org/2002/07/owl#sameAs> ?y .
    AND
    ?z <http://www.w3.org/2002/07/owl#sameAs> ?y .
}